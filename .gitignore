# Byte-compiled / optimized files (key for Python)
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments (virtualenvs)
venv/
env/
.venv/
ENV/
.conda/

# Jupyter (common in ML notebooks)
.ipynb_checkpoints/
*.ipynb_checkpoints/

# Testing / Coverage
.tox/
.coverage
.pytest_cache/
.cache/
htmlcov/

# Logs / Temp
*.log
.DS_Store
Thumbs.db

# Packaging / Builds
build/
dist/
*.egg-info/
.pip/

# Editors/IDEs
.vscode/
.idea/
*.swp

# Avoid documentation folder but keep PDFs
documentation/
!documentation/*.pdf

# Project-specific folders/files
types/
sprites/
catboost_info/
old/
notebooks/
artifacts/

# Individual files
TO_DO.md
run_commands.sh
prepare_readme.py

# Docs / Reports
*.tex
*.aux
docs/_build/

# Deployment (cloud-specific)
.env